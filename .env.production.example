# Environment variables to set in EasyPanel's "Environment" tab for this
# service. Do not commit a real .env with these filled in — set them directly
# in EasyPanel instead.

# Point this at whichever Postgres you use — an EasyPanel-hosted Postgres
# service (use its internal service name as the host, not localhost) or an
# external managed database. Must be reachable from this container.
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>"

# A random 32+ character string, unique per deployment. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET="<generate-a-random-32-plus-character-string>"

# A bcrypt hash of your real login password. Generate it locally with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" '<your-password>'
# Then escape every literal "$" in the result as "\$" before pasting it in
# here (e.g. "\$2b\$10\$...") — Next.js's env loader does shell-style
# ${VAR} interpolation and will otherwise silently corrupt the hash.
APP_PASSWORD_HASH="<escaped-bcrypt-hash>"

# Where cover images are stored inside the container. Leave as-is and mount
# a persistent volume at /app/uploads in EasyPanel — otherwise every
# redeploy wipes previously-saved cover photos.
UPLOADS_DIR="./uploads"
