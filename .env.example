DATABASE_URL="postgresql://bookcatalog:bookcatalog_dev@localhost:5432/bookcatalog"
SESSION_SECRET="replace-with-a-random-32-plus-character-string"
# Note: escape every literal "$" in the bcrypt hash as "\$" (e.g. "\$2b\$10\$...")
# — Next.js's env loader does shell-style ${VAR} interpolation and will otherwise
# silently corrupt the hash.
APP_PASSWORD_HASH="replace-with-a-bcrypt-hash-see-README"
